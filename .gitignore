# --- Solo se versiona lo necesario para el curso (resto de carpetas del disco local: ignorado) ---
/*
!/.gitignore
!/.gitattributes
!/README.md
!/requirements.txt
!/pyproject.toml
!/agentes/
!/data/
!/docs/
!/notebooks/
!/src/
!/logs/
!/slides/

# Exclusiones dentro de lo permitido
**/.mypy_cache/
**/__pycache__/
**/*.py[cod]
.venv/
venv/
env/
**/.env
**/.env.*
!**/.env.example
.idea/
.vscode/
*.code-workspace
Thumbs.db
.DS_Store

# Datos regenerables (el script los vuelve a crear)
data/raw/humaneval/
data/raw/mbpp/

# Logs de ejecución (la carpeta se versiona; el archivo se regenera)
logs/*.log

# IDE / Cursor local (si existiera bajo el repo)
**/.cursor/
